{
  "compilerOptions": {
    "composite": true,
    "jsx": "react-jsx",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "paths": {
      "@renderer/*": ["src/renderer/src/*"]
    },
    "strict": true,
    "target": "ES2020",
    "types": ["vite/client"]
  },
  "include": ["src/renderer/src/**/*"]
}
